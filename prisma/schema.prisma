generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============

enum Role {
  USER
  ADMIN
}

enum SeatType {
  REGULAR
  PREMIUM
  VIP
}

enum MovieStatus {
  COMING_SOON
  NOW_SHOWING
  ENDED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ============== MODELS ==============

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String        @map("password_hash")
  name         String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now()) @map("created_at")
  
  reservations Reservation[]
  seatLocks    SeatLock[]

  @@map("users")
}

model Theatre {
  id      Int      @id @default(autoincrement())
  name    String
  address String?  @db.Text
  city    String
  phone   String?
  
  screens Screen[]

  @@map("theatres")
}

model Screen {
  id         Int    @id @default(autoincrement())
  theatreId  Int    @map("theatre_id")
  name       String
  totalSeats Int    @map("total_seats")
  
  theatre   Theatre    @relation(fields: [theatreId], references: [id], onDelete: Cascade)
  seats     Seat[]
  showtimes Showtime[]

  @@map("screens")
}

model Seat {
  id       Int      @id @default(autoincrement())
  screenId Int      @map("screen_id")
  row      String
  number   Int
  seatType SeatType @default(REGULAR) @map("seat_type")
  
  screen        Screen         @relation(fields: [screenId], references: [id], onDelete: Cascade)
  reservedSeats ReservedSeat[]
  seatLocks     SeatLock[]

  @@unique([screenId, row, number])
  @@map("seats")
}

model Movie {
  id          Int          @id @default(autoincrement())
  title       String
  description String?      @db.Text
  duration    Int          // in minutes
  rating      Decimal?     @db.Decimal(3, 1)
  posterUrl   String?      @map("poster_url")
  releaseDate DateTime?    @map("release_date")
  genre       String?
  status      MovieStatus  @default(COMING_SOON)
  createdAt   DateTime     @default(now()) @map("created_at")
  
  showtimes Showtime[]

  @@map("movies")
}

model Showtime {
  id        Int      @id @default(autoincrement())
  movieId   Int      @map("movie_id")
  screenId  Int      @map("screen_id")
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  price     Decimal  @db.Decimal(10, 2)
  
  movie        Movie         @relation(fields: [movieId], references: [id], onDelete: Cascade)
  screen       Screen        @relation(fields: [screenId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  seatLocks    SeatLock[]

  @@unique([screenId, startTime])
  @@map("showtimes")
}

model Reservation {
  id          Int               @id @default(autoincrement())
  userId      Int               @map("user_id")
  showtimeId  Int               @map("showtime_id")
  status      ReservationStatus @default(PENDING)
  totalAmount Decimal           @map("total_amount") @db.Decimal(10, 2)
  createdAt   DateTime          @default(now()) @map("created_at")
  
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  showtime      Showtime       @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  reservedSeats ReservedSeat[]
  payment       Payment?

  @@map("reservations")
}

model ReservedSeat {
  id            Int @id @default(autoincrement())
  reservationId Int @map("reservation_id")
  seatId        Int @map("seat_id")
  
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  seat        Seat        @relation(fields: [seatId], references: [id], onDelete: Cascade)

  @@unique([reservationId, seatId])
  @@map("reserved_seats")
}

model Payment {
  id              Int           @id @default(autoincrement())
  reservationId   Int           @unique @map("reservation_id")
  stripePaymentId String?       @map("stripe_payment_id")
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now()) @map("created_at")
  
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model SeatLock {
  id         Int      @id @default(autoincrement())
  seatId     Int      @map("seat_id")
  showtimeId Int      @map("showtime_id")
  userId     Int      @map("user_id")
  expiresAt  DateTime @map("expires_at")
  
  seat     Seat     @relation(fields: [seatId], references: [id], onDelete: Cascade)
  showtime Showtime @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seatId, showtimeId])
  @@map("seat_locks")
}